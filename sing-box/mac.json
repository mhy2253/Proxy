{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "dns": {
    "servers": [
      {
        "tag": "default",
        "address": "tls://223.5.5.5",
        "detour": "direct"
      },
      {
        "tag": "alidns",
        "address": "https://dns.alidns.com/dns-query",
        "detour": "direct"
      },
      {
        "tag": "dnspub",
        "address": "https://doh.pub/dns-query",
        "detour": "direct"
      },
      {
        "tag": "fake-ip",
        "address": "fakeip"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "default"
      },
      {
        "rule_set": ["geosite-cn"],
        "server": "default"
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "server": "fake-ip"
      }
    ],
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/16",
      "inet6_range": "fc00::/18"
    },
    "independent_cache": true,
    "final": "fake-ip"
  },

  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "inet4_address": "172.19.0.1/30",
      "inet6_address": "fdfe:dcba:9876::1/126",
      "mtu": 9000,
      "auto_route": true,
      "strict_route": true,
      "stack": "system",
      "sniff": true,
      "sniff_override_destination": true
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],

  "outbounds": [
    {
      "type": "urltest",
      "tag": "proxy",
      "outbounds": ["ss", "trojan", "hysteria2", "tuic", "anytls"],
      "url": "https://cp.cloudflare.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "type": "shadowsocks",
      "tag": "ss",
      "server": "server",
      "server_port": 443,
      "method": "chacha20-ietf-poly1305",
      "password": "password"
    },
    {
      "type": "trojan",
      "tag": "trojan",
      "server": "server",
      "server_port": 443,
      "password": "yourpsk",
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "hysteria2",
      "tag": "hysteria2",
      "server": "server.com",
      "server_port": 443,
      "password": "yourpassword",
      "tls": {
        "enabled": true,
        "server_name": "server.com",
        "alpn": ["h3"],
        "insecure": false
      }
    },
    {
      "type": "tuic",
      "tag": "tuic",
      "server": "www.example.com",
      "server_port": 10443,
      "uuid": "00000000-0000-0000-0000-000000000001",
      "password": "PASSWORD_1",
      "congestion_control": "bbr",
      "udp_relay_mode": "native",
      "zero_rtt_handshake": true,
      "tls": {
        "enabled": true,
        "disable_sni": true,
        "alpn": ["h3"],
        "insecure": true
      }
    },
    {
      "type": "anytls",
      "tag": "anytls",
      "server": "1.2.3.4",
      "server_port": 443,
      "password": "<your password>",
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "block"
    },
    {
      "type": "dns",
      "tag": "dns-out"
    }
  ],

  "route": {
    "rules": [
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          { "protocol": "dns" }
        ],
        "outbound": "dns-out"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-apple-intelligence",
        "outbound": "proxy"
      },
      {
        "domain_suffix": [
          "smoot.apple.com",
          "guzzoni.apple.com",
          "apps.mzstatic.com",
          "cp4.cloudflare.com"
        ],
        "outbound": "proxy"
      },​​​​​​​​​​​​​​​​
