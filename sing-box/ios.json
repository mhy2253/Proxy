        "address": "https://doh.pub/dns-query",
        "address_resolver": "bootstrap",
        "detour": "direct"
      },
      {
        "tag": "fake-ip",
        "address": "fakeip"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "bootstrap"
      },
      {
        "rule_set": ["geosite-cn"],
        "server": "default"
      },
      {
        "domain_suffix": [
          "wechat.com",
          "weixin.qq.com",
          "servicewechat.com",
          "weixin.com"
        ],
        "server": "default"
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "server": "fake-ip"
      }
    ],
    "fakeip": {
      "enabled": true,
      "inet4_range": "198.18.0.0/16",
      "inet6_range": "fc00::/18"
    },
    "independent_cache": true,
    "final": "default"
  },

  "inbounds": [
