{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "dns": {
    "servers": [
      {
        "type": "local",
        "tag": "dns-local"
      },
      {
        "type": "tls",
        "tag": "dns-remote",
        "server": "223.5.5.5",
        "server_port": 853
      }
    ],
    "rules": [
      {
        "rule_set": ["geosite-cn"],
        "action": "route",
        "server": "dns-local"
      },
      {
        "domain_suffix": [
          "wechat.com",
          "weixin.qq.com",
          "servicewechat.com",
          "weixin.com"
        ],
        "action": "route",
        "server": "dns-local"
      },
      {
        "rule_set": ["geosite-apple"],
        "action": "route",
        "server": "dns-local"
      },
      {
        "rule_set": ["geosite-bilibili"],
        "action": "route",
        "server": "dns-local"
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "action": "route",
        "server": "dns-remote"
      }
    ],
    "independent_cache": true,
    "final": "dns-remote"
  },

  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890,
      "set_system_proxy": true
    }
  ],

  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": ["auto", "ss", "trojan", "anytls", "direct"],
      "default": "auto",
      "interrupt_exist_connections": true
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": ["ss", "trojan", "anytls"],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 50,
      "idle_timeout": "30m",
      "interrupt_exist_connections": true
    },
    {
      "type": "shadowsocks",
      "tag": "ss",
      "server": "ss.example.com",
      "server_port": 443,
      "method": "chacha20-ietf-poly1305",
      "password": "password"
    },
    {
      "type": "trojan",
      "tag": "trojan",
      "server": "trojan.example.com",
      "server_port": 443,
      "password": "yourpsk",
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "anytls",
      "tag": "anytls",
      "server": "1.2.3.4",
      "server_port": 443,
      "password": "your-password",
      "idle_session_check_interval": "30s",
      "idle_session_timeout": "30s",
      "min_idle_session": 0,
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],

  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-remote",
    "rules": [
      {
        "action": "sniff"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "wechat.com",
          "weixin.qq.com",
          "servicewechat.com",
          "weixin.com"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-apple-intelligence",
        "action": "route",
        "outbound": "proxy"
      },
      {
        "domain_suffix": [
          "smoot.apple.com",
          "guzzoni.apple.com",
          "apps.mzstatic.com",
          "cp4.cloudflare.com"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": "geosite-apple",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geosite-anthropic",
          "geosite-openai",
          "geosite-perplexity",
          "geosite-notion",
          "geosite-discord",
          "geosite-github",
          "geosite-twitter",
          "geosite-tiktok",
          "geosite-dropbox",
          "geosite-youtube",
          "geosite-google",
          "geosite-telegram",
          "geosite-netflix",
          "geosite-bahamut",
          "geosite-spotify"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": "geosite-bilibili",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-cn",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": [
          "geoip-google",
          "geoip-netflix",
          "geoip-telegram",
          "geoip-twitter"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": "geoip-cn",
        "action": "route",
        "outbound": "direct"
      }
    ],
    "rule_set": [
      {
        "tag": "geosite-apple-intelligence",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/apple-intelligence.srs",
        "download_detour": "proxy"
