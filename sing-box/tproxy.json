{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "dns": {
    "servers": [
      {
        "tag": "bootstrap",
        "type": "udp",
        "server": "223.5.5.5",
        "detour": "direct"
      },
      {
        "tag": "default",
        "type": "tls",
        "server": "223.5.5.5",
        "domain_resolver": "bootstrap",
        "detour": "direct"
      },
      {
        "tag": "alidns",
        "type": "https",
        "server": "dns.alidns.com",
        "path": "/dns-query",
        "domain_resolver": "bootstrap",
        "detour": "direct"
      },
      {
        "tag": "dnspub",
        "type": "https",
        "server": "doh.pub",
        "path": "/dns-query",
        "domain_resolver": "bootstrap",
        "detour": "direct"
      },
      {
        "tag": "fake-ip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/16",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "rule_set": ["geosite-cn"],
        "action": "route",
        "server": "default"
      },
      {
        "domain_suffix": [
          "wechat.com",
          "weixin.qq.com",
          "servicewechat.com",
          "weixin.com"
        ],
        "action": "route",
        "server": "default"
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "action": "route",
        "server": "fake-ip"
      }
    ],
    "independent_cache": true,
    "final": "default"
  },

  "inbounds": [
    {
      "type": "tproxy",
      "tag": "tproxy-in",
      "listen": "0.0.0.0",
      "listen_port": 7893,
      "tcp_fast_open": true,
      "udp_fragment": true,
      "sniff": true,
      "sniff_override_destination": true
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],

  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": ["auto", "trojan", "anytls", "ss"],
      "default": "auto"
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": ["trojan", "anytls", "ss"],
      "url": "https://cp.cloudflare.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "type": "trojan",
      "tag": "trojan",
      "server": "server",
      "server_port": 443,
      "password": "yourpsk",
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "anytls",
      "tag": "anytls",
      "server": "1.2.3.4",
      "server_port": 443,
      "password": "your_password",
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "shadowsocks",
      "tag": "ss",
      "server": "server",
      "server_port": 443,
      "method": "chacha20-ietf-poly1305",
      "password": "password"
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],

  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "wechat.com",
          "weixin.qq.com",
          "servicewechat.com",
          "weixin.com"
        ],
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geosite-anthropic",
          "geosite-openai",
          "geosite-perplexity",
          "geosite-notion",
          "geosite-discord",
          "geosite-github",
          "geosite-twitter",
          "geosite-tiktok",
          "geosite-dropbox",
          "geosite-youtube",
          "geosite-google",
          "geosite-telegram",
          "geosite-netflix",
          "geosite-bahamut",
          "geosite-spotify"
        ],
        "outbound": "proxy"
      },
      {
        "rule_set": "geosite-bilibili",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-cn",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "outbound": "proxy"
      },
      {
        "rule_set": [
          "geoip-google",
          "geoip-netflix",
          "geoip-telegram",
          "geoip-twitter"
        ],
        "outbound": "proxy"
      },
      {
        "rule_set": "geoip-cn",
        "outbound": "direct"
      }
    ],
    "rule_set": [
      {
        "tag": "geosite-anthropic",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/anthropic.srs",
        "download_detour": "proxy"
      },
      {
        "tag": "geosite-openai",
        "type": "remote",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/openai.srs",
