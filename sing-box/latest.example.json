{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "local",
        "type": "local"
      },
      {
        "tag": "cf",
        "type": "https",
        "server": "1.1.1.1",
        "server_port": 443,
        "path": "/dns-query",
        "domain_resolver": "local",
        "detour": "cloudflare",
        "tls": {
          "enabled": true,
          "server_name": "cloudflare-dns.com"
        }
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "local",
          "lan",
          "home.arpa",
          "localdomain"
        ],
        "action": "route",
        "server": "local"
      },
      {
        "rule_set": "geosite-cn",
        "action": "route",
        "server": "local"
      },
      {
        "action": "evaluate",
        "server": "cf"
      },
      {
        "match_response": true,
        "ip_is_private": true,
        "action": "route",
        "server": "local"
      },
      {
        "action": "respond"
      }
    ],
    "reverse_mapping": true,
    "final": "cf"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "singbox-tun",
      "address": [
        "172.19.0.1/30"
      ],
      "mtu": 1500,
      "auto_route": true,
      "strict_route": true,
      "stack": "system"
    }
  ],
  "outbounds": [
    {
      "type": "trojan",
      "tag": "cloudflare",
      "server": "REPLACE_WITH_SERVER_IP_OR_DOMAIN",
      "server_port": 443,
      "password": "REPLACE_WITH_TROJAN_PASSWORD",
      "tls": {
        "enabled": true,
        "server_name": "REPLACE_WITH_TLS_SERVER_NAME",
        "insecure": true
      },
      "transport": {
        "type": "ws",
        "path": "/trojan",
        "headers": {
          "Host": "REPLACE_WITH_WS_HOST"
        }
      },
      "tcp_fast_open": true
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "local",
    "final": "cloudflare",
    "rule_set": [
      {
        "type": "remote",
        "tag": "geoip-cn",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geoip/cn.srs",
        "download_detour": "direct"
      },
      {
        "type": "remote",
        "tag": "geosite-cn",
        "format": "binary",
        "url": "https://github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/cn.srs",
        "download_detour": "direct"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "local",
          "lan",
          "home.arpa",
          "localdomain"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-cn",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geoip-cn",
        "action": "route",
        "outbound": "direct"
      }
    ]
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "store_dns": true
    }
  }
}
