        "outbound": "proxy"
      },
      {
        "rule_set": "geosite-bilibili",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-cn",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-geolocation-!cn",
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": [
          "geoip-google",
          "geoip-netflix",
          "geoip-telegram",
          "geoip-twitter"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": "geoip-cn",
        "action": "route",
        "outbound": "direct"
      }
    ],
    "rule_set": [
