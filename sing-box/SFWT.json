{
  "log": {
    "level": "info",
    "timestamp": true
  },

  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "bootstrap",
        "server": "223.5.5.5"
      },
      {
        "type": "tls",
        "tag": "default",
        "server": "223.5.5.5",
        "domain_resolver": "bootstrap"
      },
      {
        "type": "fakeip",
        "tag": "fake-ip",
        "inet4_range": "198.18.0.0/16",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "bootstrap"
      },
      {
        "rule_set": ["geosite-cn"],
        "server": "default"
      },
      {
        "domain_suffix": [
          "wechat.com",
          "weixin.qq.com",
          "servicewechat.com",
          "weixin.com"
        ],
        "server": "default"
      },
      {
        "rule_set": ["geosite-geolocation-!cn"],
        "server": "fake-ip"
      }
    ],
    "independent_cache": true,
    "final": "default"
  },

  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "mtu": 9000,
      "auto_route": true,
      "strict_route": true,
      "stack": "mixed",
      "sniff": true
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 7890
    }
  ],

  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": ["auto", "ss", "trojan", "hysteria2", "tuic", "anytls"],
      "default": "auto"
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": ["ss", "trojan", "hysteria2", "tuic", "anytls"],
      "url": "https://cp.cloudflare.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "type": "shadowsocks",
      "tag": "ss",
      "server": "server",
      "server_port": 443,
      "method": "chacha20-ietf-poly1305",
      "password": "password"
    },
    {
      "type": "trojan",
      "tag": "trojan",
      "server": "server",
      "server_port": 443,
      "password": "yourpsk",
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "hysteria2",
      "tag": "hysteria2",
      "server": "server.com",
      "server_port": 443,
      "password": "yourpassword",
      "tls": {
        "enabled": true,
        "server_name": "server.com",
        "alpn": ["h3"],
        "insecure": false
      }
    },
    {
      "type": "tuic",
      "tag": "tuic",
      "server": "www.example.com",
      "server_port": 10443,
      "uuid": "00000000-0000-0000-0000-000000000001",
      "password": "PASSWORD_1",
      "congestion_control": "bbr",
      "udp_relay_mode": "native",
      "zero_rtt_handshake": true,
      "tls": {
        "enabled": true,
        "disable_sni": true,
        "alpn": ["h3"],
        "insecure": true
      }
    },
    {
      "type": "anytls",
      "tag": "anytls",
      "server": "1.2.3.4",
      "server_port": 443,
      "password": "<your password>",
      "tls": {
        "enabled": true,
        "server_name": "example.com",
        "alpn": ["h2", "http/1.1"],
        "insecure": true
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],

  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          "wechat.com",
          "weixin.qq.com",
          "servicewechat.com",
          "weixin.com"
        ],
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-apple-intelligence",
        "action": "route",
        "outbound": "proxy"
      },
      {
        "domain_suffix": [
          "smoot.apple.com",
          "guzzoni.apple.com",
          "apps.mzstatic.com",
          "cp4.cloudflare.com"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      {
        "rule_set": "geosite-apple",
        "action": "route",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geosite-anthropic",
          "geosite-openai",
          "geosite-perplexity",
          "geosite-notion",
          "geosite-discord",
          "geosite-github",
          "geosite-twitter",
          "geosite-tiktok",
          "geosite-dropbox",
          "geosite-youtube",
